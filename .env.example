OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=30

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=30
ENABLE_LOCAL_LLM=false

FRIDAY_PLANNER_MODEL=qwen2.5:1.5b
FRIDAY_ROUTER_MODEL=qwen2.5:1.5b
FRIDAY_RESEARCH_MODEL=qwen2.5:3b
FRIDAY_MEMORY_MODEL=qwen2.5:1.5b
FRIDAY_CODE_MODEL=qwen2.5-coder:1.5b
FRIDAY_EMBEDDING_MODEL=nomic-embed-text
FRIDAY_MEMORY_BACKEND=sqlite
FRIDAY_MEMORY_DB_PATH=.friday/memory/friday_memory.sqlite3

FRIDAY_PLANNER_TIMEOUT_SECONDS=6.0
FRIDAY_RESEARCH_TIMEOUT_SECONDS=12.0
FRIDAY_MEMORY_TIMEOUT_SECONDS=8.0

FRIDAY_RESEARCH_MAX_FILES=4
FRIDAY_RESEARCH_MAX_CHARS_PER_FILE=3500
FRIDAY_RESEARCH_MAX_TOTAL_CHARS=12000

FRIDAY_MEMORY_SUMMARY_MAX_CHARS=1200
FRIDAY_MEMORY_PREVIEW_MAX_CHARS=2000
